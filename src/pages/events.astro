---
// Events are fetched client-side from the calendar Worker so they're always live.
export const prerender = true;
import Base from '../layouts/Base.astro';
---
<Base title="Events" description="Upcoming Kinney Karate events, tournaments, camps, and lock-ins.">

<div class="belt"><span class="w"></span><span class="y"></span><span class="g"></span><span class="b"></span><span class="k"></span></div>

<section class="page-hero">
  <div class="container">
    <p class="eyebrow">What's Coming Up</p>
    <h1 class="cond">Events</h1>
    <p>Tournaments, camps, lock-ins, and school events — all from our Google Calendar.</p>
  </div>
</section>

<section class="pad">
  <div class="container">
    <div id="cal-root">
      <div class="cal-loading">Loading events&hellip;</div>
    </div>
  </div>
</section>

</Base>

<style>
.page-hero { background:var(--ink);color:var(--text-invert);padding:48px 0 40px; }
.page-hero h1 { font-size:52px;font-weight:700;margin-bottom:10px; }
.page-hero p { color:var(--text-invert-soft);font-size:15px; }
.pad { padding:48px 0; }

.cal-loading { color:var(--text-soft);font-size:14px;padding:40px 0;text-align:center; }
.cal-error { color:var(--danger);font-size:14px;padding:40px 0; }

/* Toolbar */
.cal-toolbar {
  display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;
  margin-bottom:28px;
}
.cal-toolbar h2 { font-family:var(--font-condensed);text-transform:uppercase;letter-spacing:.03em;font-size:24px;font-weight:700; }
.cal-tabs { display:flex;gap:4px; }
.cal-tab {
  font-size:12.5px;font-weight:600;padding:7px 16px;border-radius:6px;border:1px solid var(--line);
  background:#fff;cursor:pointer;color:var(--text-soft);transition:.12s;font-family:inherit;
}
.cal-tab.active { background:var(--ink);color:#fff;border-color:var(--ink); }
.cal-tab:hover:not(.active) { border-color:var(--ink);color:var(--ink); }

/* Agenda cards */
.ev-list { display:flex;flex-direction:column;gap:12px; }
.ev-card {
  display:flex;gap:0;align-items:stretch;
  background:#fff;border:1px solid var(--line);border-radius:var(--r-lg);
  overflow:hidden;transition:box-shadow .15s;
}
.ev-card:hover { box-shadow:0 4px 16px rgba(0,0,0,.08); }
.ev-date-block {
  background:var(--ink);color:#fff;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:16px 20px;min-width:72px;flex-shrink:0;text-align:center;
}
.ev-date-block .day { font-family:var(--font-condensed);font-size:36px;font-weight:700;line-height:1; }
.ev-date-block .mon { font-size:11px;letter-spacing:.1em;text-transform:uppercase;opacity:.75;margin-top:2px; }
.ev-date-block .dow { font-size:10px;letter-spacing:.08em;text-transform:uppercase;opacity:.55;margin-top:4px; }
.ev-body {
  padding:16px 20px;flex:1;display:flex;flex-direction:column;justify-content:center;gap:4px;
}
.ev-title { font-weight:700;font-size:15px;color:var(--ink); }
.ev-loc {
  display:flex;align-items:flex-start;gap:5px;
  font-size:12.5px;color:var(--text-soft);line-height:1.4;
}
.ev-loc svg { flex-shrink:0;margin-top:1px; }
.ev-cta { margin-top:8px; }
.ev-cta a {
  display:inline-flex;align-items:center;gap:4px;
  font-size:12.5px;font-weight:600;color:#fff;
  background:var(--red);padding:5px 14px;border-radius:6px;
  transition:opacity .12s;
}
.ev-cta a:hover { opacity:.85; }

/* Month grid */
.month-grid { display:grid;grid-template-columns:repeat(7,1fr);gap:1px;background:var(--line);border:1px solid var(--line);border-radius:var(--r);overflow:hidden; }
.month-cell { background:#fff;min-height:88px;padding:8px 6px;position:relative; }
.month-cell.other-month { background:var(--paper-2); }
.month-cell .day-num { font-size:12px;font-weight:600;color:var(--text-soft);margin-bottom:4px; }
.month-cell.today .day-num { background:var(--red);color:#fff;width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px; }
.month-ev { font-size:10.5px;background:var(--ink);color:#fff;border-radius:3px;padding:2px 5px;margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis; }
.dow-row { display:grid;grid-template-columns:repeat(7,1fr);margin-bottom:6px; }
.dow-row span { text-align:center;font-size:11px;font-weight:700;color:var(--text-soft);letter-spacing:.06em;text-transform:uppercase;padding:6px 0; }

@media (max-width:520px) {
  .ev-date-block { padding:14px 14px;min-width:60px; }
  .ev-date-block .day { font-size:28px; }
  .ev-body { padding:14px 14px; }
}
</style>

<script>
async function initCalendar() {
  const root = document.getElementById('cal-root');
  if (!root) return;

  let events = [];
  try {
    const res = await fetch('/api/calendar');
    if (!res.ok) throw new Error('fetch failed');
    events = await res.json();
  } catch {
    root.innerHTML = '<p class="cal-error">Unable to load events right now. Please check back soon.</p>';
    return;
  }

  // Sort events by start date
  events.sort((a, b) => new Date(a.start).getTime() - new Date(b.start).getTime());

  const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const FULL_MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  const DAYS = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  const FULL_DAYS = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  let view = 'agenda';

  const pinSvg = `<svg width="11" height="13" viewBox="0 0 11 13" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5.5 0C3.02 0 1 2.02 1 4.5c0 3.36 4.5 8.5 4.5 8.5S10 7.86 10 4.5C10 2.02 7.98 0 5.5 0zm0 6.25A1.75 1.75 0 1 1 5.5 2.75a1.75 1.75 0 0 1 0 3.5z" fill="currentColor"/></svg>`;

  function renderAgenda() {
    const now = new Date();
    const upcoming = events.filter(e => new Date(e.end || e.start) >= now);
    if (!upcoming.length) return '<p class="cal-loading">No upcoming events scheduled.</p>';
    return `<div class="ev-list">` + upcoming.map(e => {
      const d = new Date(e.start);
      const loc = e.location ? `<div class="ev-loc">${pinSvg}<span>${e.location}</span></div>` : '';
      const cta = e.url ? `<div class="ev-cta"><a href="${e.url}" target="_blank" rel="noopener">Details →</a></div>` : '';
      return `<div class="ev-card">
        <div class="ev-date-block">
          <div class="dow">${FULL_DAYS[d.getDay()]}</div>
          <div class="day">${d.getDate()}</div>
          <div class="mon">${MONTHS[d.getMonth()]} ${d.getFullYear()}</div>
        </div>
        <div class="ev-body">
          <div class="ev-title">${e.title}</div>
          ${loc}${cta}
        </div>
      </div>`;
    }).join('') + `</div>`;
  }

  function renderMonth() {
    const now = new Date();
    const year = now.getFullYear(), month = now.getMonth();
    const first = new Date(year, month, 1).getDay();
    const days = new Date(year, month + 1, 0).getDate();
    let cells = '';
    for (let i = 0; i < first; i++) cells += '<div class="month-cell other-month"></div>';
    for (let d = 1; d <= days; d++) {
      const isToday = d === now.getDate();
      const dayEvents = events.filter(e => {
        const ed = new Date(e.start);
        return ed.getFullYear() === year && ed.getMonth() === month && ed.getDate() === d;
      });
      const evHtml = dayEvents.map(e => `<div class="month-ev" title="${e.title}">${e.title}</div>`).join('');
      cells += `<div class="month-cell${isToday ? ' today' : ''}"><div class="day-num">${d}</div>${evHtml}</div>`;
    }
    const dowRow = DAYS.map(d => `<span>${d}</span>`).join('');
    return `<div class="dow-row">${dowRow}</div><div class="month-grid">${cells}</div>`;
  }

  function render() {
    const monthLabel = new Date().toLocaleString('en-US', { month: 'long', year: 'numeric' });
    root.innerHTML = `
      <div class="cal-toolbar">
        <h2>${view === 'month' ? monthLabel : 'Upcoming Events'}</h2>
        <div class="cal-tabs">
          <button class="cal-tab${view==='agenda'?' active':''}" data-v="agenda">Agenda</button>
          <button class="cal-tab${view==='month'?' active':''}" data-v="month">Month</button>
        </div>
      </div>
      <div id="cal-body">${view === 'month' ? renderMonth() : renderAgenda()}</div>`;
    root.querySelectorAll('.cal-tab').forEach(btn => {
      btn.addEventListener('click', () => { view = (btn as HTMLButtonElement).dataset.v as any; render(); });
    });
  }

  render();
}

document.addEventListener('DOMContentLoaded', initCalendar);
</script>
