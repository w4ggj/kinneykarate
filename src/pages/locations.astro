---
export const prerender = true;
import Base from '../layouts/Base.astro';

interface Location {
  name: string;
  address: string;
  schedule: { day: string; time: string; level: string }[];
  pricing?: string;
  note?: string;
  mapUrl: string;
  phone?: string;
}

const locations: Location[] = [
  {
    name: 'JW Cate Recreation Center',
    address: '5454 4th Ave N, St. Petersburg, FL 33710',
    schedule: [
      { day: 'Tuesday & Thursday', time: '6:00 PM', level: 'Beginner' },
      { day: 'Tuesday & Thursday', time: '7:00 PM', level: 'Intermediate' },
    ],
    pricing: '$30/month (1× per week) · $60/month (2× per week)',
    note: 'Tuition paid in person to the City of St. Petersburg Parks & Recreation.',
    mapUrl: 'https://maps.google.com/?q=JW+Cate+Recreation+Center+St+Petersburg+FL',
  },
  {
    name: 'Willis S Johns Recreation Center',
    address: '6085 54th Ave N, St. Petersburg, FL 33709',
    schedule: [
      { day: 'Tuesday & Thursday', time: '6:00 PM', level: 'Beginner' },
      { day: 'Tuesday & Thursday', time: '7:00 PM', level: 'Intermediate' },
    ],
    pricing: '$30/month (1× per week) · $60/month (2× per week)',
    note: 'Tuition paid in person to the City of St. Petersburg Parks & Recreation.',
    mapUrl: 'https://maps.google.com/?q=Willis+S+Johns+Recreation+Center+St+Petersburg+FL',
  },
  {
    name: 'Gladden Park Recreation Center',
    address: 'St. Petersburg, FL',
    schedule: [
      { day: 'Monday & Wednesday', time: '6:00 PM', level: 'Beginner' },
      { day: 'Monday & Wednesday', time: '7:00 PM', level: 'Intermediate' },
    ],
    mapUrl: 'https://maps.google.com/?q=Gladden+Park+St+Petersburg+FL',
  },
  {
    name: 'Lake Vista Recreation Center',
    address: 'St. Petersburg, FL',
    schedule: [
      { day: 'Monday & Thursday', time: '6:00 PM', level: 'Beginner' },
      { day: 'Monday & Thursday', time: '6:00 PM', level: 'Intermediate' },
    ],
    mapUrl: 'https://maps.google.com/?q=Lake+Vista+Recreation+Center+St+Petersburg+FL',
  },
  {
    name: 'Balance Dojo',
    address: '6701 49th St N, Pinellas Park, FL 33781',
    schedule: [
      { day: 'See schedule', time: '', level: 'Advanced & specialty classes' },
    ],
    note: 'Advanced training and specialty programs. Contact us for details.',
    mapUrl: 'https://maps.google.com/?q=6701+49th+St+N+Pinellas+Park+FL+33781',
  },
];
---
<Base title="Locations & Schedule" description="Find Kinney Karate classes at recreation centers and our dojo in St. Petersburg, FL.">

<div class="belt"><span class="w"></span><span class="y"></span><span class="g"></span><span class="b"></span><span class="k"></span></div>

<section class="page-hero">
  <div class="container">
    <p class="eyebrow">Where to Train</p>
    <h1 class="cond">Locations &amp; Schedule</h1>
    <p>Kinney Karate operates at St. Petersburg Recreation Centers and the Balance Dojo.</p>
  </div>
</section>

<section class="pad">
  <div class="container">
    <p class="kick">Our Locations</p>
    <div class="loc-grid">
      {locations.map(l => (
        <div class="loc-card">
          <h2>{l.name}</h2>
          <p class="addr">{l.address}</p>
          <table class="sched">
            {l.schedule.map(s => (
              <tr>
                <td class="sday">{s.day}</td>
                {s.time && <td class="stime">{s.time}</td>}
                <td class="slevel">{s.level}</td>
              </tr>
            ))}
          </table>
          {l.pricing && <p class="pricing">{l.pricing}</p>}
          {l.note && <p class="note">{l.note}</p>}
          <a href={l.mapUrl} target="_blank" rel="noopener" class="map-link">View on map →</a>
        </div>
      ))}
    </div>

    <div class="schedule-note">
      <h3>Tuition &amp; Registration</h3>
      <p>Recreation Center classes are administered through the City of St. Petersburg Parks &amp; Recreation. Tuition is <strong>$30/month for one class per week</strong> or <strong>$60/month for two classes per week</strong> — paid in person at the Recreation Center. Your first class is always free.</p>
      <p style="margin-top:10px"><strong>Tuition is never paid on this website.</strong> Advanced dojo billing is handled through <a href="https://balancemartialarts.com" target="_blank" rel="noopener" style="color:var(--red)">Balance Martial Arts</a>.</p>
      <p style="margin-top:10px">Questions? Call <a href="tel:+17276860864" style="color:var(--red);font-weight:600">727-686-0864</a> or use the <a href="/about#contact" style="color:var(--red)">contact form</a>.</p>
    </div>
  </div>
</section>

</Base>

<style>
.page-hero {
  background: var(--ink); color: var(--text-invert);
  padding: 48px 0 40px;
}
.page-hero h1 { font-size: 52px; font-weight: 700; margin-bottom: 10px; }
.page-hero p { color: var(--text-invert-soft); font-size: 15px; }
.pad { padding: 48px 0; }
.loc-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
  margin-bottom: 32px;
}
@media (max-width: 620px) { .loc-grid { grid-template-columns: 1fr; } }
.loc-card {
  border: 1px solid var(--line);
  border-radius: var(--r-lg);
  background: #fff;
  padding: 24px;
}
.loc-card h2 { font-weight: 700; font-size: 17px; margin-bottom: 8px; }
.loc-card .addr { font-size: 13px; color: var(--text-soft); margin-bottom: 10px; }
.loc-card .days { font-size: 14px; margin-bottom: 6px; }
.loc-card .note { font-size: 13px; color: var(--text-soft); margin-bottom: 14px; }
.map-link { font-size: 13px; color: var(--red); font-weight: 600; }
.sched { border-collapse: collapse; margin-bottom: 10px; font-size: 13px; }
.sched td { padding: 3px 10px 3px 0; vertical-align: top; }
.sday { font-weight: 600; color: var(--text); white-space: nowrap; }
.stime, .slevel { color: var(--text-soft); }
.pricing { font-size: 13px; font-weight: 600; color: var(--ink); margin-bottom: 6px; }
.schedule-note {
  background: var(--paper);
  border: 1px solid var(--line);
  border-radius: var(--r);
  padding: 24px;
}
.schedule-note h3 { font-weight: 700; margin-bottom: 10px; }
.schedule-note p { font-size: 14px; color: var(--text-soft); line-height: 1.7; }
</style>
