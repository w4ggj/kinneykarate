---
export const prerender = true;
import Base from '../layouts/Base.astro';

const posts = [
  {
    title: '6 Reasons to Start Martial Arts',
    date: 'May 2025',
    excerpt: 'Thinking about trying martial arts but not sure where to start? Here are six compelling reasons why people of all ages are discovering the benefits of training — from improved fitness and self-defense skills to greater confidence and a sense of community.',
    body: [
      '<strong>1. Physical fitness that's actually fun.</strong> Martial arts workouts build strength, flexibility, coordination, and cardiovascular endurance — without ever feeling like a chore. Every class is different, every class challenges you.',
      '<strong>2. Real self-defense skills.</strong> You'll learn practical techniques drawn from Tang Soo Do, Aikido, Ju Jitsu, and Modern Arnis — arts tested over centuries, not invented for sport.',
      '<strong>3. Discipline and focus.</strong> The structure of a martial arts class translates directly into everyday life. Students consistently report improvements in focus at school and work.',
      '<strong>4. Confidence that you earned.</strong> Every belt, every technique mastered, every challenge overcome builds real confidence — the kind that comes from knowing what you're capable of.',
      '<strong>5. A community that has your back.</strong> Kinney Karate has been a family for over 55 years. You won't just learn to fight — you'll make lifelong friends.',
      '<strong>6. It's never too late to start.</strong> We have students who began training in their 60s. Your first class is always free. Come find out what you've been missing.',
    ],
  },
  {
    title: '3 Ways Martial Arts Cultivates Resilience',
    date: 'April 2025',
    excerpt: 'Resilience — the ability to recover from setbacks and keep moving forward — is one of the most valuable qualities a person can develop. Martial arts training builds it in ways that go far beyond the dojo.',
    body: [
      '<strong>1. You learn to fall and get back up.</strong> Literally. In Ju Jitsu and Aikido, you practice falling safely hundreds of times. The lesson sinks in: falling is not failing. Getting back up is the point.',
      '<strong>2. Progress is non-linear — and that\'s okay.</strong> Every martial artist hits plateaus. You'll work on a technique for months before it clicks. Learning to stay patient, trust the process, and keep showing up is itself the training.',
      '<strong>3. Challenge is the curriculum.</strong> Every class pushes you past your comfort zone — a little or a lot, depending on the day. Over time, you stop fearing challenge and start seeking it. That shift doesn\'t stay in the dojo.',
    ],
  },
];
---
<Base title="News & Articles" description="Latest news, articles, and updates from Kinney Karate.">

<div class="belt"><span class="w"></span><span class="y"></span><span class="g"></span><span class="b"></span><span class="k"></span></div>

<section class="page-hero">
  <div class="container">
    <p class="eyebrow">From the School</p>
    <h1 class="cond">News &amp; Articles</h1>
  </div>
</section>

<section class="pad">
  <div class="container">
    <div class="posts">
      {posts.map(post => (
        <article class="post-card">
          <p class="post-date">{post.date}</p>
          <h2 class="cond">{post.title}</h2>
          <p class="excerpt">{post.excerpt}</p>
          <div class="post-body">
            {post.body.map(para => <p set:html={para} />)}
          </div>
        </article>
      ))}
    </div>
    <p class="archive-link">Want more? <a href="https://us4.campaign-archive.com/home/?u=8b17df13c78ba3f3f4e0d8a94&id=TODO" target="_blank" rel="noopener">Read the newsletter archive →</a></p>
  </div>
</section>

</Base>

<style>
.page-hero { background:var(--ink);color:var(--text-invert);padding:48px 0 40px; }
.page-hero h1 { font-size:52px;font-weight:700; }
.pad { padding:48px 0; }
.posts { display:flex;flex-direction:column;gap:32px;max-width:760px; }
.post-card { border:1px solid var(--line);border-radius:var(--r);background:#fff;padding:28px; }
.post-date { font-size:12px;color:var(--text-soft);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px; }
.post-card h2 { font-size:26px;font-weight:700;margin-bottom:12px; }
.excerpt { font-size:15px;color:var(--text-soft);margin-bottom:20px;line-height:1.7; }
.post-body p { font-size:14px;color:var(--text-soft);line-height:1.8;margin-bottom:12px; }
.archive-link { margin-top:32px;font-size:14px;color:var(--text-soft); }
.archive-link a { color:var(--red);font-weight:600; }
</style>
