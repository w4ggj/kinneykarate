---
export const prerender = true;
import Base from '../layouts/Base.astro';
---
<Base title="Home" description="Kinney Karate — Tang Soo Do, Aikido, Ju Jitsu & Modern Arnis. St. Petersburg, FL. First class free.">

<!-- Belt ribbon -->
<div class="belt"><span class="w"></span><span class="y"></span><span class="g"></span><span class="b"></span><span class="k"></span></div>

<!-- Hero -->
<section class="hero">
  <div class="hero-banner">
    <img src="/logo-header.png" alt="Kinney Karate Martial Arts System" class="hero-banner-img" />
  </div>
  <div class="container hero-content">
    <p class="eyebrow">St. Petersburg, FL &mdash; Founded 1969</p>
    <p class="sub">Traditional martial arts for all ages &mdash; Tang Soo Do, Aikido, Ju Jitsu, and Modern Arnis. Build discipline, self-defense skills, and lasting confidence.</p>
    <div class="herocta">
      <a href="/programs" class="btn">Explore Programs</a>
      <a href="/locations" class="btn ghost">Locations &amp; Schedule</a>
      <span class="since"><b>55+</b> years of martial arts excellence</span>
    </div>
  </div>
</section>

<!-- Why Kinney Karate -->
<section class="why pad">
  <div class="container">
    <h2 class="cond why-heading">Why Kinney Karate?</h2>

    <!-- Feature boxes -->
    <div class="feat-row">
      <div class="feat-box">
        <div class="feat-icon">⭐</div>
        <div>
          <strong>Student Benefits</strong>
          <p>Real-world skills, fitness, focus, and a supportive community that keeps students coming back.</p>
        </div>
      </div>
      <div class="feat-box">
        <div class="feat-icon">🏆</div>
        <div>
          <strong>Award-Winning Martial Arts Training</strong>
          <p>Over 55 years of excellence in Tang Soo Do, Aikido, Ju Jitsu, and Modern Arnis.</p>
        </div>
      </div>
      <div class="feat-box">
        <div class="feat-icon">🥋</div>
        <div>
          <strong>Classes for All Ages &amp; Levels</strong>
          <p>From young children to adults — beginners to advanced. Everyone belongs on this mat.</p>
        </div>
      </div>
    </div>

    <!-- Three-column layout -->
    <div class="why-cols">
      <div class="why-col">
        <h3 class="cond why-col-head">Discipline.</h3>
        <ul class="check-list">
          <li>Structured, respectful learning environment</li>
          <li>Focus and attention skills that transfer to school &amp; work</li>
          <li>Consistent belt-rank progression with clear goals</li>
          <li>Habits of punctuality, effort, and follow-through</li>
          <li>Respect for instructors, peers, and self</li>
        </ul>
      </div>

      <div class="why-col why-col-center">
        <div class="instructor-photo-wrap">
          <img src="/instructor.jpg" alt="Kinney Karate instructor with student" class="instructor-photo" />
        </div>
      </div>

      <div class="why-col">
        <h3 class="cond why-col-head why-col-head--right">Self-Defense. Confidence.</h3>
        <ul class="check-list">
          <li>Practical techniques from multiple martial arts systems</li>
          <li>Situational awareness and de-escalation skills</li>
          <li>Physical fitness, balance, and coordination</li>
          <li>Public speaking and demonstration confidence</li>
          <li>Earned self-assurance from real achievement</li>
        </ul>
      </div>
    </div>

    <!-- Philosophy -->
    <div class="philosophy">
      <p>One of the great things about Kinney Karate is its flexibility in tailoring itself to the individual student. Whether your child needs an outlet for energy, a challenge to push past, or a community to belong to — our instructors meet every student where they are and help them grow into the best version of themselves.</p>
    </div>
  </div>
</section>

<!-- First class free -->
<section class="free-class">
  <div class="container free-class-inner">
    <div>
      <p class="eyebrow">New Students</p>
      <h2 class="cond">Your First Class is Free</h2>
      <p>Come see what Kinney Karate is all about — no commitment, no cost. Just show up ready to learn.</p>
    </div>
    <div>
      <a href="/students#new" class="btn">Get Started</a>
    </div>
  </div>
</section>

<!-- Programs preview -->
<section class="programs pad">
  <div class="container">
    <p class="kick">Programs</p>
    <div class="grid4">
      {[
        { slug:'tang-soo-do', label:'Tang Soo Do', color:'var(--belt-black)', desc:'Traditional Korean karate — the heart of our curriculum.' },
        { slug:'aikido',      label:'Aikido',      color:'var(--belt-brown)', desc:'Harmony and redirection — elegant, effective self-defense.' },
        { slug:'ju-jitsu',   label:'Ju Jitsu',    color:'var(--belt-green)', desc:'Ground techniques and joint locks for all body types.' },
        { slug:'arnis',      label:'Modern Arnis', color:'var(--belt-yellow)', desc:'Filipino stick &amp; blade art — fast, fun, and formidable.' },
      ].map(p => (
        <a href={`/programs#${p.slug}`} class="prog">
          <div class="rank" style={`background:${p.color}`}></div>
          <p class="pt">{p.label}</p>
          <p class="pd" set:html={p.desc} />
        </a>
      ))}
    </div>
    <div style="margin-top:20px;text-align:center">
      <a href="/programs" class="btn dark">View All Programs</a>
    </div>
  </div>
</section>

<!-- Locations preview -->
<section class="locs pad" style="background:var(--paper)">
  <div class="container">
    <p class="kick">Locations</p>
    <div class="grid3">
      {[
        { name: 'JW Cate Recreation Center', note: 'Mon / Wed / Fri', city: 'St. Petersburg' },
        { name: 'Willis S Johns Recreation Center', note: 'Mon / Wed / Fri', city: 'St. Petersburg' },
        { name: 'Gladden Park Recreation Center', note: 'See schedule', city: 'St. Petersburg' },
        { name: 'Lake Vista Recreation Center', note: 'See schedule', city: 'St. Petersburg' },
        { name: 'Balance Dojo', note: 'Advanced classes — see schedule', city: 'Pinellas Park' },
      ].map(l => (
        <div class="loc-card">
          <h3>{l.name}</h3>
          <p>{l.note}</p>
          <p class="city">{l.city}, FL</p>
        </div>
      ))}
    </div>
    <div style="margin-top:20px;text-align:center">
      <a href="/locations" class="btn dark">Full Schedule</a>
    </div>
  </div>
</section>

<!-- Store preview -->
<section class="store-preview pad">
  <div class="container">
    <p class="kick">Student Store</p>
    <p style="margin-bottom:20px;max-width:560px;">Official Kinney Karate uniforms, sparring gear, t-shirts, and more. Only KK-branded gear is permitted in class.</p>
    <a href="/store" class="btn">Shop the Store</a>
  </div>
</section>

</Base>

<style>
.hero {
  background: var(--ink);
  color: var(--text-invert);
}
.hero-banner {
  background: #000;
  text-align: center;
  line-height: 0;
}
.hero-banner-img {
  width: 100%;
  max-width: 900px;
  height: auto;
  display: inline-block;
}
.hero-content {
  padding: 36px 0 48px;
}
.hero .sub {
  max-width: 480px;
  color: var(--text-invert-soft);
  font-size: 15px;
  margin-bottom: 28px;
}
.herocta { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
.since { margin-left: auto; text-align: right; color: var(--text-invert-soft); font-size: 12px; }
.since b { display: block; font-family: var(--font-condensed); font-size: 32px; color: #fff; }

.pad { padding: 48px 0; }

/* Why Kinney Karate section */
.why { background: var(--paper); }
.why-heading { font-size: 38px; font-weight: 700; text-align: center; margin-bottom: 28px; }

.feat-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 40px; }
@media (max-width: 720px) { .feat-row { grid-template-columns: 1fr; } }

.feat-box {
  display: flex; align-items: flex-start; gap: 14px;
  background: #fff; border: 1px solid var(--line); border-radius: var(--r-lg); padding: 20px;
}
.feat-icon { font-size: 24px; flex-shrink: 0; }
.feat-box strong { display: block; font-weight: 700; font-size: 14px; margin-bottom: 4px; }
.feat-box p { font-size: 13px; color: var(--text-soft); margin: 0; }

.why-cols { display: grid; grid-template-columns: 1fr auto 1fr; gap: 32px; align-items: start; margin-bottom: 32px; }
@media (max-width: 820px) { .why-cols { grid-template-columns: 1fr; } .why-col-center { order: -1; } }

.why-col-head { font-size: 26px; font-weight: 700; color: var(--red); margin-bottom: 14px; text-transform: uppercase; letter-spacing: .02em; }
.why-col-head--right { text-align: right; }
@media (max-width: 820px) { .why-col-head--right { text-align: left; } }

.check-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
.check-list li { font-size: 14px; padding-left: 22px; position: relative; color: var(--text); line-height: 1.4; }
.check-list li::before { content: '✓'; position: absolute; left: 0; color: var(--red); font-weight: 700; }

.why-col-center { display: flex; align-items: center; justify-content: center; }
.instructor-photo-wrap { width: 180px; }
.instructor-photo { width: 180px; height: 180px; object-fit: contain; border-radius: 50%; border: 4px solid var(--red); display: block; }

.philosophy {
  max-width: 680px; margin: 0 auto; padding: 24px 28px;
  background: var(--ink); color: var(--text-invert); border-radius: var(--r-lg);
  font-size: 15px; line-height: 1.65; font-style: italic; text-align: center;
}

.free-class {
  background: var(--red);
  color: #fff;
  padding: 40px 0;
}
.free-class-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  flex-wrap: wrap;
}
.free-class h2 { font-size: 36px; font-weight: 700; margin-bottom: 6px; }
.free-class p { font-size: 14px; opacity: .85; }
.free-class .btn { background: #fff; color: var(--red); font-size: 14px; }
.free-class .btn:hover { background: var(--paper); }

.prog {
  display: block;
  border: 1px solid var(--line);
  border-radius: var(--r);
  padding: 18px;
  background: #fff;
  transition: box-shadow .15s;
}
.prog:hover { box-shadow: 0 4px 16px -8px rgba(20,23,27,.18); }
.prog .rank { width: 28px; height: 6px; border-radius: 3px; margin-bottom: 14px; }
.prog .pt { font-family: var(--font-condensed); text-transform: uppercase; font-weight: 700; font-size: 19px; letter-spacing: .02em; margin-bottom: 6px; }
.prog .pd { color: var(--text-soft); font-size: 13px; }

.loc-card {
  border: 1px solid var(--line);
  border-radius: var(--r);
  padding: 20px;
  background: #fff;
}
.loc-card h3 { font-weight: 600; font-size: 15px; margin-bottom: 6px; }
.loc-card p { font-size: 13px; color: var(--text-soft); }
.loc-card .city { margin-top: 4px; }
</style>
