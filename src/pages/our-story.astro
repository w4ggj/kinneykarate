---
<Base title="Our Story" description="The history of Kinney Karate — founded by Soke Michael Kinney, shaped by 50+ years of training and legendary mentors.">

<div class="belt"><span class="w"></span><span class="y"></span><span class="g"></span><span class="b"></span><span class="k"></span></div>

<section class="page-hero">
  <div class="container">
    <p class="eyebrow">Who We Are</p>
    <h1 class="cond">Our Story</h1>
  </div>
</section>

<section class="pad">
  <div class="container">
    {sections.map(sec => (
      <div class="story-section">
        <h2 class="section-heading cond">{sec.heading}</h2>
        {sec.intro && <p class="section-intro">{sec.intro}</p>}
        {sec.items.map(item => (
          item.label ? (
            <details class="accordion">
              <summary class="accordion-toggle">{item.label} <span class="chevron">▾</span></summary>
              <div class="accordion-body">
                {item.body.split('\n\n').map((para: string) => (
                  <p>{para}</p>
                ))}
              </div>
            </details>
          ) : (
            <p class="section-body">{item.body}</p>
          )
        ))}
      </div>
    ))}
  </div>
</section>

</Base>

<style>
.page-hero { background:var(--ink);color:var(--text-invert);padding:48px 0 40px; }
.page-hero h1 { font-size:52px;font-weight:700;margin-bottom:10px; }
.pad { padding:48px 0; }

.story-section {
  margin-bottom: 48px;
}
.section-heading {
  font-size: 28px;
  font-weight: 700;
  margin-bottom: 8px;
  color: var(--ink);
}
.section-intro {
  font-size: 15px;
  color: var(--text-soft);
  font-style: italic;
  margin-bottom: 20px;
  line-height: 1.7;
  max-width: 720px;
}
.section-body {
  font-size: 15px;
  color: var(--text-soft);
  line-height: 1.8;
  max-width: 720px;
}

.accordion {
  border: 1px solid var(--line);
  border-radius: var(--r-lg);
  background: #fff;
  margin-bottom: 10px;
  overflow: hidden;
}
.accordion-toggle {
  list-style: none;
  cursor: pointer;
  padding: 16px 20px;
  font-size: 15px;
  font-weight: 600;
  color: var(--ink);
  display: flex;
  align-items: center;
  justify-content: space-between;
  user-select: none;
  gap: 12px;
}
.accordion-toggle::-webkit-details-marker { display: none; }
.accordion-toggle:hover { color: var(--red); }
.chevron { font-size: 11px; transition: transform .2s; flex-shrink: 0; }
details[open] .chevron { transform: rotate(180deg); }
details[open] .accordion-toggle { border-bottom: 1px solid var(--line); }

.accordion-body {
  padding: 20px 20px 20px;
}
.accordion-body p {
  font-size: 14px;
  color: var(--text-soft);
  line-height: 1.8;
  margin-bottom: 14px;
  max-width: 720px;
}
.accordion-body p:last-child { margin-bottom: 0; }
</style>
