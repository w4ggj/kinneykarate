---
export const prerender = true;
import Base from '../layouts/Base.astro';
---
<Base title="Memorial Fund" description="The Soke Kinney Memorial Fund honors the legacy of Grand Master Soke Michael Kinney, founder of Kinney Karate.">

<div class="belt"><span class="w"></span><span class="y"></span><span class="g"></span><span class="b"></span><span class="k"></span></div>

<section class="page-hero">
  <div class="container">
    <p class="eyebrow">Legacy</p>
    <h1 class="cond">Soke Kinney Memorial Fund</h1>
  </div>
</section>

<section class="pad">
  <div class="container">
    <div class="memorial-card">
      <div class="memorial-photos">
        <img src="/Michael-student-remastered.png" alt="Grand Master Soke Michael Kinney" class="memorial-photo" />
        <img src="/michael-w-kid-sm.png" alt="Grand Master Soke Michael Kinney with student" class="memorial-photo" />
      </div>
      <h2>In Memory of Grand Master Soke Michael Kinney</h2>
      <p>The Soke Kinney Memorial Fund is a nonprofit established to honor the legacy of Kinney Karate's founder. The fund supports martial arts education and community programs in St. Petersburg.</p>
      <p>The Memorial Fund operates independently of Kinney Karate retail. Donations and fund activities are handled separately — visit <a href="https://www.sokekinneymemorial.org/home" target="_blank" rel="noopener">sokekinneymemorial.org</a> for more information.</p>
      <p><em>The Soke Kinney Memorial patch is available in the <a href="/store">school store</a> — a small way to carry his legacy.</em></p>
    </div>
  </div>
</section>

</Base>

<style>
.page-hero { background:var(--ink);color:var(--text-invert);padding:48px 0 40px; }
.page-hero h1 { font-size:52px;font-weight:700;margin-bottom:10px; }
.pad { padding:48px 0; }
.memorial-card {
  border:1px solid var(--line);border-radius:var(--r-lg);background:#fff;padding:28px;max-width:760px;
}
.memorial-photos {
  display:flex;gap:16px;margin-bottom:20px;flex-wrap:wrap;
}
.memorial-photo {
  width:180px;height:220px;object-fit:cover;object-position:top;
  border-radius:var(--r);border:1px solid var(--line);
}
.memorial-card h2 { font-weight:700;font-size:22px;margin-bottom:14px; }
.memorial-card p { font-size:14px;color:var(--text-soft);margin-bottom:10px;line-height:1.7; }
.memorial-card a { color:var(--red); }
</style>
