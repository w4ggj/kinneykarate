---
export const prerender = false;
import Base from '../layouts/Base.astro';

const CATEGORIES = [
  'Automotive','Business Support & Supplies','Computers & Electronics',
  'Construction & Contractors','Education','Entertainment','Food & Dining',
  'Health & Medicine','Home & Garden','Legal & Financial',
  'Manufacturing, Wholesale, Distribution','Merchants (Retail)',
  'Miscellaneous','Personal Care & Services','Real Estate','Sports',
  'Travel & Transportation',
];

const env = (Astro.locals as any).runtime?.env;
let listings: any[] = [];
if (env?.DB) {
  const res = await env.DB.prepare(`
    SELECT id, business_name, owner_name, category, description, phone, email, website, city, state, zip
    FROM business_listings WHERE approved = 1
    ORDER BY category, business_name
  `).all();
  listings = res.results ?? [];
}

// Group by category
const byCategory: Record<string, any[]> = {};
for (const l of listings) {
  if (!byCategory[l.category]) byCategory[l.category] = [];
  byCategory[l.category].push(l);
}

// Category counts
const counts: Record<string, number> = {};
for (const cat of CATEGORIES) counts[cat] = byCategory[cat]?.length ?? 0;
---
<Base title="Karate Family Business Directory" description="Business listings owned by members of the Kinney Karate family.">

<div class="belt"><span class="w"></span><span class="y"></span><span class="g"></span><span class="b"></span><span class="k"></span></div>

<section class="page-hero">
  <div class="container hero-content">
    <p class="eyebrow">Community</p>
    <h1 class="cond">Karate Family Business Directory</h1>
    <p>The business listings below are owned by members of the Kinney Karate Family. If you are part of the Kinney Karate Family and own a business, click the button below to list your business.</p>
  </div>
</section>

<section class="pad">
  <div class="container">

    <!-- Filters -->
    <div class="filter-bar">
      <div class="filter-row">
        <div class="filter-field">
          <select id="cat-filter">
            <option value="">All Categories</option>
            {CATEGORIES.map(c => <option value={c}>{c}</option>)}
          </select>
        </div>
        <div class="filter-field">
          <input type="text" id="search-input" placeholder="Search businesses…" />
        </div>
        <button id="reset-btn" class="reset-btn">Reset</button>
      </div>
    </div>

    <!-- Submit button -->
    <div style="margin:24px 0 32px">
      <button id="submit-btn" class="btn submit-btn">+ Submit New Listing</button>
    </div>

    <!-- Category count grid -->
    <div id="cat-grid" class="cat-grid">
      {CATEGORIES.map(c => (
        <button class="cat-row" data-cat={c}>
          <span class="cat-name">{c}</span>
          <span class="cat-count">{counts[c]}</span>
        </button>
      ))}
    </div>

    <!-- Listings -->
    <div id="listings-section" style="display:none">
      <h2 id="listings-heading" class="listings-heading"></h2>
      <div id="listings-grid" class="listings-grid"></div>
      <button id="back-btn" class="back-btn">← Back to Categories</button>
    </div>

    <!-- All listings (search results) -->
    <div id="search-results" style="display:none">
      <h2 class="listings-heading">Search Results</h2>
      <div id="search-grid" class="listings-grid"></div>
    </div>

  </div>
</section>

<!-- Submit Modal -->
<div id="modal-overlay" class="modal-overlay" style="display:none" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="modal">
    <div class="modal-header">
      <h2 id="modal-title">Submit Your Business Listing</h2>
      <button id="modal-close" class="modal-close" aria-label="Close">✕</button>
    </div>
    <p class="modal-note">Listings are reviewed before being published. You will be contacted if we need more information.</p>
    <form id="submit-form" class="submit-form" novalidate>
      <div class="form-row">
        <div class="form-group">
          <label>Business Name *</label>
          <input name="business_name" type="text" required />
        </div>
        <div class="form-group">
          <label>Your Name *</label>
          <input name="owner_name" type="text" required />
        </div>
      </div>
      <div class="form-group">
        <label>Category *</label>
        <select name="category" required>
          <option value="">— Select category —</option>
          {CATEGORIES.map(c => <option value={c}>{c}</option>)}
        </select>
      </div>
      <div class="form-group">
        <label>Description * <span class="label-hint">(what does your business do?)</span></label>
        <textarea name="description" rows={3} required></textarea>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>City</label>
          <input name="city" type="text" />
        </div>
        <div class="form-group">
          <label>ZIP</label>
          <input name="zip" type="text" maxlength={10} />
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Phone</label>
          <input name="phone" type="tel" />
        </div>
        <div class="form-group">
          <label>Email</label>
          <input name="email" type="email" />
        </div>
      </div>
      <div class="form-group">
        <label>Website</label>
        <input name="website" type="url" placeholder="https://" />
      </div>
      <div id="form-error" class="form-error" style="display:none"></div>
      <div id="form-success" class="form-success" style="display:none">
        Your listing has been submitted! We'll review it and publish it shortly.
      </div>
      <div class="form-actions">
        <button type="submit" id="form-submit-btn" class="btn">Submit Listing</button>
        <button type="button" id="modal-cancel" class="cancel-btn">Cancel</button>
      </div>
    </form>
  </div>
</div>

</Base>

<script define:vars={{ listingsData: listings, CATEGORIES }}>
  // Build a lookup by category
  const byCategory = {};
  for (const l of listingsData) {
    if (!byCategory[l.category]) byCategory[l.category] = [];
    byCategory[l.category].push(l);
  }

  function cardHTML(l) {
    const loc = [l.city, l.state].filter(Boolean).join(', ');
    return `<div class="listing-card">
      <div class="lc-name">${esc(l.business_name)}</div>
      <div class="lc-owner">Owner: ${esc(l.owner_name)}</div>
      ${loc ? `<div class="lc-loc">📍 ${esc(loc)}</div>` : ''}
      <p class="lc-desc">${esc(l.description)}</p>
      <div class="lc-contact">
        ${l.phone ? `<a href="tel:${esc(l.phone)}">${esc(l.phone)}</a>` : ''}
        ${l.email ? `<a href="mailto:${esc(l.email)}">${esc(l.email)}</a>` : ''}
        ${l.website ? `<a href="${esc(l.website)}" target="_blank" rel="noopener">Website →</a>` : ''}
      </div>
    </div>`;
  }

  function esc(s) {
    return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  const catGrid = document.getElementById('cat-grid');
  const listingsSection = document.getElementById('listings-section');
  const listingsHeading = document.getElementById('listings-heading');
  const listingsGrid = document.getElementById('listings-grid');
  const backBtn = document.getElementById('back-btn');
  const searchResults = document.getElementById('search-results');
  const searchGrid = document.getElementById('search-grid');
  const catFilter = document.getElementById('cat-filter');
  const searchInput = document.getElementById('search-input');
  const resetBtn = document.getElementById('reset-btn');

  function showCategory(cat) {
    const items = byCategory[cat] ?? [];
    listingsHeading.textContent = cat;
    listingsGrid.innerHTML = items.length
      ? items.map(cardHTML).join('')
      : '<p class="empty-msg">No listings in this category yet. Be the first to submit!</p>';
    catGrid.style.display = 'none';
    listingsSection.style.display = 'block';
    searchResults.style.display = 'none';
    catFilter.value = cat;
  }

  function showAll() {
    catGrid.style.display = 'grid';
    listingsSection.style.display = 'none';
    searchResults.style.display = 'none';
    catFilter.value = '';
    searchInput.value = '';
  }

  // Category row buttons
  catGrid.querySelectorAll('.cat-row').forEach(btn => {
    btn.addEventListener('click', () => showCategory(btn.dataset.cat));
  });

  backBtn.addEventListener('click', showAll);

  catFilter.addEventListener('change', () => {
    if (catFilter.value) showCategory(catFilter.value);
    else showAll();
  });

  searchInput.addEventListener('input', () => {
    const q = searchInput.value.trim().toLowerCase();
    if (!q) { showAll(); return; }
    const results = listingsData.filter(l =>
      l.business_name.toLowerCase().includes(q) ||
      l.description.toLowerCase().includes(q) ||
      l.category.toLowerCase().includes(q) ||
      (l.city || '').toLowerCase().includes(q) ||
      (l.owner_name || '').toLowerCase().includes(q)
    );
    searchGrid.innerHTML = results.length
      ? results.map(cardHTML).join('')
      : '<p class="empty-msg">No listings found.</p>';
    catGrid.style.display = 'none';
    listingsSection.style.display = 'none';
    searchResults.style.display = 'block';
  });

  resetBtn.addEventListener('click', showAll);

  // Modal
  const overlay = document.getElementById('modal-overlay');
  const form = document.getElementById('submit-form');
  const formError = document.getElementById('form-error');
  const formSuccess = document.getElementById('form-success');
  const submitFormBtn = document.getElementById('form-submit-btn');

  function openModal() { overlay.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
  function closeModal() { overlay.style.display = 'none'; document.body.style.overflow = ''; }

  document.getElementById('submit-btn').addEventListener('click', openModal);
  document.getElementById('modal-close').addEventListener('click', closeModal);
  document.getElementById('modal-cancel').addEventListener('click', closeModal);
  overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(); });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    formError.style.display = 'none';
    formSuccess.style.display = 'none';
    submitFormBtn.disabled = true;
    submitFormBtn.textContent = 'Submitting…';

    const data = Object.fromEntries(new FormData(form));
    try {
      const res = await fetch('/api/directory/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json();
      if (!res.ok) throw new Error(json.error || 'Submission failed');
      formSuccess.style.display = 'block';
      form.reset();
      submitFormBtn.style.display = 'none';
    } catch (err) {
      formError.textContent = err.message;
      formError.style.display = 'block';
      submitFormBtn.disabled = false;
      submitFormBtn.textContent = 'Submit Listing';
    }
  });
</script>

<style>
.page-hero {
  background: var(--ink); color: var(--text-invert);
  padding: 48px 0 40px;
}
.page-hero h1 { font-size: 44px; font-weight: 700; margin-bottom: 10px; }
.page-hero p { color: var(--text-invert-soft); font-size: 15px; line-height: 1.7; max-width: 680px; }

.pad { padding: 40px 0 64px; }

/* Filter bar */
.filter-bar {
  background: #fff;
  border: 1px solid var(--line);
  border-radius: var(--r-lg);
  padding: 20px;
}
.filter-row {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  align-items: center;
}
.filter-field { flex: 1; min-width: 180px; }
.filter-field select,
.filter-field input {
  width: 100%;
  padding: 10px 14px;
  border: 1px solid var(--line);
  border-radius: var(--r);
  font-size: 14px;
  background: #fff;
  font-family: inherit;
}
.reset-btn {
  padding: 10px 24px;
  border: 1px solid var(--line);
  border-radius: var(--r);
  background: #fff;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  color: var(--red);
  transition: background .12s;
}
.reset-btn:hover { background: var(--paper); }

/* Submit button */
.submit-btn {
  font-size: 15px;
  padding: 12px 28px;
}

/* Category grid */
.cat-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0;
  border: 1px solid var(--line);
  border-radius: var(--r-lg);
  overflow: hidden;
  margin-bottom: 32px;
}
@media (max-width: 600px) { .cat-grid { grid-template-columns: 1fr; } }

.cat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 18px;
  background: var(--paper);
  border: none;
  border-bottom: 1px solid var(--line);
  cursor: pointer;
  text-align: left;
  font-family: inherit;
  transition: background .12s;
}
.cat-row:hover { background: #e8e9ec; }
.cat-row:last-child { border-bottom: none; }
.cat-name { font-size: 14px; color: var(--text); }
.cat-count {
  font-size: 13px;
  font-weight: 700;
  color: var(--text-soft);
  background: #ddd;
  border-radius: 999px;
  min-width: 24px;
  text-align: center;
  padding: 2px 8px;
}
.cat-row:hover .cat-name { color: var(--red); }

/* Listings */
.listings-heading { font-size: 22px; font-weight: 700; margin-bottom: 20px; }
.listings-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 16px;
  margin-bottom: 24px;
}
.listing-card {
  border: 1px solid var(--line);
  border-radius: var(--r-lg);
  background: #fff;
  padding: 20px;
}
.lc-name { font-weight: 700; font-size: 16px; margin-bottom: 4px; }
.lc-owner { font-size: 12px; color: var(--text-soft); margin-bottom: 4px; }
.lc-loc { font-size: 12px; color: var(--text-soft); margin-bottom: 8px; }
.lc-desc { font-size: 13px; color: var(--text-soft); line-height: 1.6; margin-bottom: 12px; }
.lc-contact { display: flex; flex-direction: column; gap: 4px; }
.lc-contact a { font-size: 13px; color: var(--red); font-weight: 500; }
.empty-msg { color: var(--text-soft); font-style: italic; }

.back-btn {
  background: none; border: none; cursor: pointer;
  color: var(--red); font-weight: 600; font-size: 14px;
  padding: 0; font-family: inherit;
}
.back-btn:hover { text-decoration: underline; }

/* Modal */
.modal-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,.55);
  display: flex; align-items: center; justify-content: center;
  z-index: 500;
  padding: 20px;
}
.modal {
  background: #fff;
  border-radius: var(--r-lg);
  width: 100%;
  max-width: 580px;
  max-height: 90vh;
  overflow-y: auto;
  padding: 28px;
}
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}
.modal-header h2 { font-size: 20px; font-weight: 700; }
.modal-close {
  background: none; border: none; cursor: pointer;
  font-size: 18px; color: var(--text-soft);
  line-height: 1; padding: 4px;
}
.modal-note { font-size: 13px; color: var(--text-soft); margin-bottom: 20px; }

.submit-form { display: flex; flex-direction: column; gap: 14px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
@media (max-width: 500px) { .form-row { grid-template-columns: 1fr; } }
.form-group { display: flex; flex-direction: column; gap: 5px; }
.form-group label { font-size: 13px; font-weight: 600; color: var(--text); }
.label-hint { font-weight: 400; color: var(--text-soft); }
.form-group input,
.form-group select,
.form-group textarea {
  padding: 9px 12px;
  border: 1px solid var(--line);
  border-radius: var(--r);
  font-size: 14px;
  font-family: inherit;
  background: #fff;
}
.form-group textarea { resize: vertical; }
.form-error { color: #c00; font-size: 13px; padding: 10px; background: #fff0f0; border-radius: var(--r); }
.form-success { color: #1a7f3c; font-size: 14px; padding: 12px; background: #f0fff5; border-radius: var(--r); font-weight: 600; }
.form-actions { display: flex; gap: 12px; align-items: center; margin-top: 4px; }
.cancel-btn {
  background: none; border: none; cursor: pointer;
  color: var(--text-soft); font-size: 14px; font-family: inherit;
}
.cancel-btn:hover { color: var(--text); }
</style>
