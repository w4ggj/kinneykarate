---
export const prerender = false;
import Base from '../../layouts/Base.astro';

const env = (Astro.locals as any).runtime?.env;
const SUPABASE_URL = env?.SUPABASE_URL || env?.PUBLIC_SUPABASE_URL || '';
const SUPABASE_ANON_KEY = env?.SUPABASE_ANON_KEY || env?.PUBLIC_SUPABASE_ANON_KEY || '';

// Check session cookie set by client-side Supabase login
const cookie = Astro.cookies.get('kk_admin_session');
const authed = cookie?.value === 'authenticated';
---
<Base title="Admin Console">

{!authed && (
  <div class="login-wrap">
    <div class="login-box">
      <div class="login-logo">
        <img src="/kklogo.png" alt="Kinney Karate" width="48" height="48" />
        <h1>Kinney Karate</h1>
        <p>Admin Console</p>
      </div>
      <div id="login-error" class="login-error" style="display:none"></div>
      <div class="login-field">
        <label for="email">Email address</label>
        <input type="email" id="email" required autocomplete="email" autofocus />
      </div>
      <div class="login-field">
        <label for="password">Password</label>
        <input type="password" id="password" required autocomplete="current-password" />
      </div>
      <button class="btn block" id="signin-btn" style="margin-top:8px">Sign In</button>
    </div>
  </div>
  <script define:vars={{ SUPABASE_URL, SUPABASE_ANON_KEY }}>
    async function signIn() {
      const email = document.getElementById('email').value.trim();
      const password = document.getElementById('password').value;
      const errEl = document.getElementById('login-error');
      const btn = document.getElementById('signin-btn');
      errEl.style.display = 'none';
      btn.disabled = true;
      btn.textContent = 'Signing in…';

      if (!SUPABASE_URL) {
        errEl.textContent = 'Admin login is not configured. Add SUPABASE env vars in Cloudflare.';
        errEl.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Sign In';
        return;
      }

      try {
        const res = await fetch(SUPABASE_URL + '/auth/v1/token?grant_type=password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_ANON_KEY },
          body: JSON.stringify({ email, password }),
        });
        const data = await res.json();
        if (!res.ok || !data.access_token) {
          errEl.textContent = data.error_description || data.msg || 'Incorrect email or password.';
          errEl.style.display = 'block';
          btn.disabled = false;
          btn.textContent = 'Sign In';
          return;
        }
        document.cookie = 'kk_admin_session=authenticated; path=/admin; max-age=604800; SameSite=Lax';
        window.location.reload();
      } catch (e) {
        errEl.textContent = 'Network error: ' + e.message;
        errEl.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Sign In';
      }
    }

    document.getElementById('signin-btn').addEventListener('click', signIn);
    document.getElementById('password').addEventListener('keydown', function(e) { if (e.key === 'Enter') signIn(); });
  </script>
)}

{authed && (
<style>
  body { background: var(--paper-2); }
  .admin-layout { display: flex; min-height: calc(100vh - 120px); }
  .admin-nav {
    width: 220px; flex-shrink: 0;
    background: var(--ink); color: var(--text-invert);
    padding: 24px 0;
  }
  .admin-nav .nav-section { padding: 0 16px; margin-bottom: 24px; }
  .admin-nav .nav-label {
    font-size: 10px; font-weight: 700; letter-spacing: .12em;
    text-transform: uppercase; color: var(--text-invert-soft);
    margin-bottom: 8px; padding: 0 4px;
  }
  .admin-nav a {
    display: block; padding: 8px 12px; border-radius: 6px;
    font-size: 13.5px; color: var(--text-invert-soft); font-weight: 500;
    transition: .12s; margin-bottom: 2px;
  }
  .admin-nav a:hover, .admin-nav a.active { background: var(--ink-2); color: #fff; }
  .admin-main { flex: 1; padding: 32px; overflow-x: hidden; min-width: 0; }
  .admin-main h1 { font-family: var(--font-condensed); text-transform: uppercase; font-size: 28px; font-weight: 700; margin-bottom: 24px; }

  @media (max-width: 820px) {
    .admin-layout { flex-direction: column; }
    .admin-nav {
      width: 100%; padding: 0;
      overflow-x: auto; -webkit-overflow-scrolling: touch;
      display: flex; flex-direction: row; align-items: stretch;
      scrollbar-width: none;
    }
    .admin-nav::-webkit-scrollbar { display: none; }
    .admin-nav .nav-section {
      display: flex; flex-direction: row; align-items: stretch;
      padding: 0; margin: 0; flex-shrink: 0;
      border-right: 1px solid rgba(255,255,255,.08);
    }
    .admin-nav .nav-section:last-child { border-right: none; }
    .admin-nav .nav-label { display: none; }
    .admin-nav a {
      display: flex; align-items: center;
      padding: 12px 14px; border-radius: 0; margin: 0;
      font-size: 13px; white-space: nowrap;
      border-bottom: 3px solid transparent;
    }
    .admin-nav a:hover, .admin-nav a.active {
      background: transparent; color: #fff;
      border-bottom-color: var(--red);
    }
    .admin-main { padding: 16px; }
    .admin-main h1 { font-size: 22px; margin-bottom: 16px; }
  }

  /* Tables */
  .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .data-table { width: 100%; border-collapse: collapse; font-size: 13.5px; background: #fff; border: 1px solid var(--line); border-radius: var(--r); overflow: hidden; }
  .data-table th { background: var(--ink); color: #fff; padding: 10px 14px; text-align: left; font-weight: 600; font-size: 12px; letter-spacing: .04em; }
  .data-table td { padding: 10px 14px; border-bottom: 1px solid var(--line); }
  .data-table tr:last-child td { border-bottom: none; }
  .data-table tr:hover td { background: var(--paper-2); }

  /* Status badges */
  .badge { font-size: 11px; font-weight: 600; padding: 3px 8px; border-radius: 999px; }
  .badge.paid { background: #d1fae5; color: #065f46; }
  .badge.in_production { background: #fef3c7; color: #92400e; }
  .badge.ready { background: #dbeafe; color: #1e40af; }
  .badge.picked_up { background: var(--paper-2); color: var(--text-soft); }
  .badge.mto { background: #fef3c7; color: #92400e; }
  .badge.low { background: #fee2e2; color: #991b1b; }
  .badge.ok { background: #d1fae5; color: #065f46; }

  .btn-sm { font-size: 12px; padding: 5px 10px; }

  /* Scan panel */
  .scan-instructions { background: #f0f4ff; border: 1px solid #c7d4f0; border-radius: var(--r-lg); padding: 16px 20px; max-width: 600px; margin-bottom: 20px; font-size: 14px; line-height: 1.7; }
  .scan-instructions ol { margin: 8px 0 0 18px; padding: 0; }
  .scan-panel { background: #fff; border: 1px solid var(--line); border-radius: var(--r-lg); padding: 24px; max-width: 480px; margin-bottom: 24px; }
  .scan-panel h2 { font-weight: 700; font-size: 18px; margin-bottom: 14px; }
  .scan-input { display: flex; gap: 8px; }
  .scan-input input { flex: 1; border: 2px solid var(--ink); border-radius: var(--r); padding: 10px 14px; font-size: 15px; font-family: var(--font-mono); min-width: 0; }
  .scan-input input:focus { outline: none; border-color: var(--red); }
  .scan-result { margin-top: 14px; font-size: 14px; }
  .scan-mode-btns { display: flex; gap: 8px; margin-bottom: 12px; flex-wrap: wrap; }
  .mode-btn { padding: 8px 16px; border-radius: var(--r); font-weight: 600; font-size: 13px; border: 2px solid var(--line); background: #fff; cursor: pointer; }
  .mode-btn.active { border-color: var(--ink); background: var(--ink); color: #fff; }

  @media (max-width: 600px) {
    .scan-panel { max-width: 100%; padding: 16px; }
    .scan-instructions { padding: 12px 14px; }
    .scan-input { flex-wrap: wrap; }
    .scan-input input { width: 100%; }
    .scan-input .btn { width: 100%; }
  }

  .tabs { display: flex; gap: 4px; margin-bottom: 24px; flex-wrap: wrap; }
  .tab { padding: 8px 18px; border-radius: 6px; font-weight: 600; font-size: 13px; border: 1px solid var(--line); background: #fff; cursor: pointer; color: var(--text-soft); }
  .tab.active { background: var(--ink); color: #fff; border-color: var(--ink); }

  #loading { color: var(--text-soft); font-size: 14px; padding: 20px 0; }
  .toggle-row { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; }
  .toggle { position: relative; width: 44px; height: 24px; }
  .toggle input { opacity: 0; width: 0; height: 0; }
  .toggle-slider { position: absolute; inset: 0; background: var(--line); border-radius: 24px; cursor: pointer; transition: .2s; }
  .toggle input:checked + .toggle-slider { background: var(--ok); }
  .toggle-slider::before { content: ''; position: absolute; width: 18px; height: 18px; left: 3px; bottom: 3px; background: #fff; border-radius: 50%; transition: .2s; }
  .toggle input:checked + .toggle-slider::before { transform: translateX(20px); }
</style>

<div class="admin-layout">
  <nav class="admin-nav">
    <div class="nav-section">
      <p class="nav-label">Inventory</p>
      <a href="#" data-panel="inventory" class="active">Stock &amp; Scanning</a>
      <a href="#" data-panel="movements">Movements Log</a>
    </div>
    <div class="nav-section">
      <p class="nav-label">Orders</p>
      <a href="#" data-panel="orders">All Orders</a>
      <a href="#" data-panel="queue">Made-to-Order Queue</a>
    </div>
    <div class="nav-section">
      <p class="nav-label">Catalog</p>
      <a href="#" data-panel="products">Products</a>
    </div>
    <div class="nav-section">
      <p class="nav-label">Community</p>
      <a href="#" data-panel="directory">Business Directory</a>
    </div>
    <div class="nav-section">
      <p class="nav-label">Site</p>
      <a href="#" data-panel="settings">Settings</a>
    </div>
    <div class="nav-section">
      <p class="nav-label">Other Sites</p>
      <a href="https://www.balance-your-world.com/staff" target="_blank" rel="noopener">Balance Your World</a>
      <a href="https://camp.kinneykarate.com/admin" target="_blank" rel="noopener">KK Camp</a>
    </div>
    <div class="nav-section" style="margin-top:auto;padding-top:24px">
      <a href="/admin/logout" style="color:var(--text-invert-soft);font-size:13px">Sign Out</a>
    </div>
  </nav>

  <main class="admin-main">
    <div id="panel-content">
      <p id="loading">Loading…</p>
    </div>
  </main>
</div>

<script>
type Panel = 'inventory'|'movements'|'orders'|'queue'|'products'|'directory'|'settings';
let currentPanel: Panel = 'inventory';

const navLinks = document.querySelectorAll<HTMLAnchorElement>('[data-panel]');
navLinks.forEach(a => {
  a.addEventListener('click', e => {
    e.preventDefault();
    navLinks.forEach(n => n.classList.remove('active'));
    a.classList.add('active');
    loadPanel(a.dataset.panel as Panel);
  });
});

async function api(path: string, opts?: RequestInit) {
  const res = await fetch(path, opts);
  if (!res.ok) throw new Error(await res.text());
  return res.json();
}

function fmt(cents: number | null) { return cents ? '$' + (cents/100).toFixed(0) : '—'; }
function esc(s: any) { return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

// ── PANELS ────────────────────────────────────────────────────────────────────

async function loadPanel(panel: Panel) {
  currentPanel = panel;
  const el = document.getElementById('panel-content')!;
  el.innerHTML = '<p id="loading">Loading…</p>';

  if (panel === 'inventory') await renderInventory(el);
  else if (panel === 'movements') await renderMovements(el);
  else if (panel === 'orders') await renderOrders(el);
  else if (panel === 'queue') await renderQueue(el);
  else if (panel === 'products') await renderProducts(el);
  else if (panel === 'directory') await renderDirectory(el);
  else if (panel === 'settings') await renderSettings(el);
}

async function renderInventory(el: HTMLElement) {
  const rows = await api('/admin/api/inventory');
  let scanMode = 'check_in';

  el.innerHTML = `
    <h1>Stock &amp; Barcode Scanning</h1>
    <div class="scan-instructions">
      <strong>How to use:</strong>
      <ol>
        <li>Select <b>Check In</b> when receiving new stock, or <b>Check Out</b> when selling an item in person.</li>
        <li>Set the <b>quantity</b> using the dropdown (defaults to 1).</li>
        <li>Scan the item's barcode — the count updates automatically.</li>
        <li>If a barcode is unrecognized, a dropdown will appear — select the matching item and tap <b>Map</b>, then scan again.</li>
      </ol>
    </div>
    <div class="scan-panel">
      <h2>Scan Item</h2>
      <div class="scan-mode-btns">
        <button class="mode-btn active" data-mode="check_in">Check In (received)</button>
        <button class="mode-btn" data-mode="take_out">Take Out (in-person sale)</button>
      </div>
      <div class="scan-input">
        <select id="scan-qty" style="font-size:18px;padding:10px 14px;min-width:80px;border:1px solid var(--line);border-radius:var(--r);touch-action:manipulation">
          ${Array.from({length:10},(_,i)=>`<option value="${i+1}">${i+1}</option>`).join('')}
        </select>
        <input type="text" id="scan-field" placeholder="Scan barcode…" autofocus />
        <button class="btn" id="scan-submit">Scan</button>
      </div>
      <div class="scan-result" id="scan-result"></div>
    </div>
    <div class="table-wrap"><table class="data-table">
      <thead><tr><th>Product</th><th>Size</th><th>Color</th><th>Barcode</th><th>On Hand</th><th>Status</th></tr></thead>
      <tbody>${rows.map((r: any) => {
        const low = r.on_hand <= r.low_stock_threshold;
        const badge = r.on_hand < 0 ? `<span class="badge low">Backordered (${Math.abs(r.on_hand)})</span>`
          : low ? `<span class="badge low">Low (${r.on_hand})</span>`
          : `<span class="badge ok">${r.on_hand} in stock</span>`;
        return `<tr>
          <td>${esc(r.product_name)}</td>
          <td>${esc(r.size||'—')}</td>
          <td>${esc(r.color||'—')}</td>
          <td class="mono">${esc(r.barcode||'—')}</td>
          <td>${r.on_hand}</td>
          <td>${badge}</td>
        </tr>`;
      }).join('')}</tbody>
    </table></div>`;

  el.querySelectorAll('.mode-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      el.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      scanMode = (btn as HTMLButtonElement).dataset.mode!;
    });
  });

  async function doScan() {
    const field = document.getElementById('scan-field') as HTMLInputElement;
    const qtyEl = document.getElementById('scan-qty') as HTMLSelectElement;
    const resultEl = document.getElementById('scan-result')!;
    const barcode = field.value.trim();
    if (!barcode) return;
    const qty = parseInt(qtyEl.value) || 1;
    try {
      const r = await api('/admin/api/inventory/scan', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ barcode, mode: scanMode, qty, staff: 'admin' }),
      });
      if (r.unknown) {
        const variants = await api('/admin/api/variants');
        const opts = variants.map((v: any) => {
          const label = [v.product_name, v.size, v.color].filter(Boolean).join(' / ');
          const already = v.barcode ? ` [${v.barcode}]` : '';
          return `<option value="${v.id}">${esc(label)}${esc(already)}</option>`;
        }).join('');
        resultEl.innerHTML = `
          <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
            <span style="color:var(--warn)">Unknown: <b>${esc(barcode)}</b></span>
            <select id="map-select" style="flex:1;min-width:200px;padding:6px 8px;border:1px solid var(--line);border-radius:var(--r)">
              <option value="">— pick item —</option>${opts}
            </select>
            <button class="btn btn-sm" id="map-btn">Map</button>
          </div>`;
        document.getElementById('map-btn')?.addEventListener('click', () => {
          const vid = (document.getElementById('map-select') as HTMLSelectElement).value;
          if (!vid) return;
          api('/admin/api/inventory/map', {
            method: 'POST', headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ barcode, variant_id: vid }),
          }).then(() => {
            resultEl.innerHTML = '<span style="color:var(--ok)">✓ Barcode mapped! Scan again to record stock.</span>';
          });
        });
      } else {
        const action = scanMode === 'check_in' ? `+${qty} received` : `-${qty} taken out`;
        resultEl.innerHTML = `<span style="color:var(--ok)">✓ ${esc(r.variant.product_name)} ${esc(r.variant.size||'')} ${esc(r.variant.color||'')} — ${action} — on hand: <b>${r.on_hand}</b></span>`;
        loadPanel('inventory');
      }
    } catch {
      resultEl.innerHTML = '<span style="color:var(--danger)">Scan failed. Check connection.</span>';
    }
    field.value = '';
    qtyEl.value = '1';
    field.focus();
  }

  document.getElementById('scan-submit')?.addEventListener('click', doScan);
  document.getElementById('scan-field')?.addEventListener('keydown', e => { if (e.key === 'Enter') doScan(); });
}

async function renderMovements(el: HTMLElement) {
  const rows = await api('/admin/api/inventory/movements?limit=100');
  el.innerHTML = `
    <h1>Inventory Movements</h1>
    <div class="table-wrap"><table class="data-table">
      <thead><tr><th>Time</th><th>Product</th><th>Size</th><th>Δ Qty</th><th>Reason</th><th>Source</th><th>Staff</th><th>Order</th></tr></thead>
      <tbody>${rows.map((r: any) => `<tr>
        <td>${new Date(r.created_at).toLocaleString()}</td>
        <td>${esc(r.product_name)}</td>
        <td>${esc(r.size||'—')}</td>
        <td style="font-weight:700;color:${r.delta>0?'var(--ok)':'var(--danger)'}">${r.delta > 0 ? '+' : ''}${r.delta}</td>
        <td>${esc(r.reason)}</td>
        <td>${esc(r.source)}</td>
        <td>${esc(r.staff||'—')}</td>
        <td class="mono" style="font-size:12px">${esc(r.order_id||'—')}</td>
      </tr>`).join('')}</tbody>
    </table></div>`;
}

async function renderOrders(el: HTMLElement) {
  const rows = await api('/admin/api/orders?limit=100');
  el.innerHTML = `
    <h1>Orders</h1>
    <div class="table-wrap"><table class="data-table">
      <thead><tr><th>Date</th><th>Student</th><th>Location</th><th>Instructor</th><th>Total</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody>${rows.map((o: any) => `<tr>
        <td>${new Date(o.created_at).toLocaleDateString()}</td>
        <td>${esc(o.student_name)}</td>
        <td>${esc(o.location)}</td>
        <td>${esc(o.instructor_name)}</td>
        <td>${fmt(o.total_cents)}</td>
        <td><span class="badge ${o.status}">${o.status}</span></td>
        <td>
          <select data-order-id="${esc(o.id)}" class="status-select" style="font-size:12px;padding:4px 8px;border:1px solid var(--line);border-radius:4px">
            ${['paid','in_production','ready','picked_up','canceled'].map(s => `<option${s===o.status?' selected':''}>${s}</option>`).join('')}
          </select>
        </td>
      </tr>`).join('')}</tbody>
    </table></div>`;

  el.querySelectorAll('.status-select').forEach(sel => {
    sel.addEventListener('change', async (e) => {
      const s = e.target as HTMLSelectElement;
      await api(`/admin/api/orders/${s.dataset.orderId}/status`, {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ status: s.value }),
      });
    });
  });
}

async function renderQueue(el: HTMLElement) {
  const rows = await api('/admin/api/queue');
  el.innerHTML = `
    <h1>Made-to-Order Queue</h1>
    <div class="table-wrap"><table class="data-table">
      <thead><tr><th>Due By</th><th>Item</th><th>Sizes</th><th>Color</th><th>Student</th><th>Location</th><th>Instructor</th><th>Status</th></tr></thead>
      <tbody>${rows.map((i: any) => {
        const compStr = i.components?.map((c: any) => `${c.component_name}: ${c.chosen_size}`).join(', ') || (i.size || '—');
        const badge = i.backordered ? '<span class="badge low">Backordered</span>' : '<span class="badge mto">MTO</span>';
        return `<tr>
          <td>${i.produce_by || '—'}</td>
          <td>${esc(i.name_snapshot)}</td>
          <td style="font-size:12px">${esc(compStr)}</td>
          <td>${esc(i.color||'—')}</td>
          <td>${esc(i.student_name)}</td>
          <td>${esc(i.location)}</td>
          <td>${esc(i.instructor_name)}</td>
          <td>${badge}</td>
        </tr>`;
      }).join('')}</tbody>
    </table></div>`;
}

async function renderProducts(el: HTMLElement) {
  const rows = await api('/admin/api/products');
  el.innerHTML = `
    <h1>Products</h1>
    <div class="table-wrap"><table class="data-table">
      <thead><tr><th>Name</th><th>Category</th><th>Kind</th><th>Fulfillment</th><th>Special Order</th><th>Active</th></tr></thead>
      <tbody>${rows.map((p: any) => `<tr>
        <td><a href="/store/${esc(p.slug)}" target="_blank" style="color:var(--red)">${esc(p.name)}</a></td>
        <td>${esc(p.category)}</td>
        <td>${esc(p.kind)}</td>
        <td>${esc(p.fulfillment_type)}</td>
        <td>${p.special_order ? 'Yes' : 'No'}</td>
        <td>${p.active ? '✓' : '—'}</td>
      </tr>`).join('')}</tbody>
    </table></div>`;
}

const DIR_CATS = ['Automotive','Business Support & Supplies','Computers & Electronics','Construction & Contractors','Education','Entertainment','Food & Dining','Health & Medicine','Home & Garden','Legal & Financial','Manufacturing, Wholesale, Distribution','Merchants (Retail)','Miscellaneous','Personal Care & Services','Real Estate','Sports','Technology & Software','Travel & Transportation'];

async function renderDirectory(el: HTMLElement) {
  let allRows: any[] = await api('/admin/api/directory/listings');

  function tableHTML(rows: any[]) {
    if (!rows.length) return '<p style="color:var(--text-soft);font-style:italic">No listings yet.</p>';
    return `<div class="table-wrap"><table class="data-table" style="table-layout:fixed;width:100%">
      <colgroup>
        <col style="width:180px"><col style="width:150px"><col style="width:140px">
        <col style="width:90px"><col style="width:130px"><col>
        <col style="width:140px">
      </colgroup>
      <thead><tr>
        <th>Business</th><th>Status</th><th>Category</th><th>Location</th><th>Contact</th><th>Description</th><th>Actions</th>
      </tr></thead>
      <tbody>
      ${rows.map(r => `<tr data-id="${r.id}">
        <td><strong style="font-size:13px">${esc(r.business_name)}</strong><br><span style="font-size:11px;color:var(--text-soft)">${esc(r.owner_name)}</span></td>
        <td>
          <div style="display:flex;flex-direction:column;gap:6px;min-width:120px">
            ${!r.approved ? `<span style="display:inline-block;background:#fef3c7;color:#92400e;font-size:11px;font-weight:600;padding:2px 8px;border-radius:999px;width:fit-content">Pending review</span>` : ''}
            <div style="display:flex;align-items:center;gap:8px">
              <label class="toggle" style="flex-shrink:0">
                <input type="checkbox" class="dir-toggle" data-id="${r.id}" ${r.approved ? 'checked' : ''}>
                <span class="toggle-slider"></span>
              </label>
              <span style="font-size:13px;font-weight:600;color:${r.approved ? '#16a34a' : 'var(--text-soft)'}">${r.approved ? 'Published' : 'Unpublished'}</span>
            </div>
            <div style="font-size:11px;color:var(--text-soft)">Tap to ${r.approved ? 'unpublish' : 'publish'}</div>
          </div>
        </td>
        <td style="font-size:12px">${esc(r.category)}</td>
        <td style="font-size:12px">${esc([r.city, r.zip].filter(Boolean).join(', '))}</td>
        <td style="font-size:11px;word-break:break-all;overflow-wrap:break-word">
          ${r.phone ? `<div>${esc(r.phone)}</div>` : ''}
          ${r.email ? `<div>${esc(r.email)}</div>` : ''}
          ${r.website ? `<div><a href="${esc(r.website)}" target="_blank" rel="noopener" style="color:var(--red);word-break:break-all">${esc(r.website)}</a></div>` : ''}
        </td>
        <td style="font-size:12px;color:var(--text-soft);word-break:break-word">${esc(r.description)}</td>
        <td>
          <div style="display:flex;flex-direction:column;gap:6px">
            <button class="dir-edit btn" data-id="${r.id}" style="font-size:12px;padding:5px 12px">Edit</button>
            <button class="dir-delete" data-id="${r.id}" style="font-size:12px;padding:5px 12px;background:none;border:1px solid #fca5a5;border-radius:var(--r);cursor:pointer;color:#c00">Delete</button>
          </div>
        </td>
      </tr>`).join('')}
      </tbody>
    </table></div>`;
  }

  function editModalHTML(r: any) {
    const catOpts = DIR_CATS.map(c => `<option value="${esc(c)}" ${r.category===c?'selected':''}>${esc(c)}</option>`).join('');
    return `<div id="dir-modal-overlay" style="position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:500;display:flex;align-items:center;justify-content:center;padding:20px">
      <div style="background:#fff;border-radius:var(--r-lg);width:100%;max-width:560px;max-height:90vh;overflow-y:auto;padding:28px">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
          <h2 style="font-size:18px;font-weight:700">Edit Listing</h2>
          <button id="dir-modal-close" style="background:none;border:none;font-size:20px;cursor:pointer;color:var(--text-soft)">✕</button>
        </div>
        <form id="dir-edit-form" style="display:flex;flex-direction:column;gap:14px">
          <input type="hidden" name="id" value="${r.id}">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
            <div><label style="font-size:13px;font-weight:600;display:block;margin-bottom:4px">Business Name</label>
              <input name="business_name" value="${esc(r.business_name)}" style="width:100%;padding:8px 10px;border:1px solid var(--line);border-radius:var(--r);font-size:13px;font-family:inherit"></div>
            <div><label style="font-size:13px;font-weight:600;display:block;margin-bottom:4px">Owner Name</label>
              <input name="owner_name" value="${esc(r.owner_name)}" style="width:100%;padding:8px 10px;border:1px solid var(--line);border-radius:var(--r);font-size:13px;font-family:inherit"></div>
          </div>
          <div><label style="font-size:13px;font-weight:600;display:block;margin-bottom:4px">Category</label>
            <select name="category" style="width:100%;padding:8px 10px;border:1px solid var(--line);border-radius:var(--r);font-size:13px;font-family:inherit">${catOpts}</select></div>
          <div><label style="font-size:13px;font-weight:600;display:block;margin-bottom:4px">Description</label>
            <textarea name="description" rows="3" style="width:100%;padding:8px 10px;border:1px solid var(--line);border-radius:var(--r);font-size:13px;font-family:inherit;resize:vertical">${esc(r.description)}</textarea></div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
            <div><label style="font-size:13px;font-weight:600;display:block;margin-bottom:4px">City</label>
              <input name="city" value="${esc(r.city||'')}" style="width:100%;padding:8px 10px;border:1px solid var(--line);border-radius:var(--r);font-size:13px;font-family:inherit"></div>
            <div><label style="font-size:13px;font-weight:600;display:block;margin-bottom:4px">ZIP</label>
              <input name="zip" value="${esc(r.zip||'')}" style="width:100%;padding:8px 10px;border:1px solid var(--line);border-radius:var(--r);font-size:13px;font-family:inherit"></div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
            <div><label style="font-size:13px;font-weight:600;display:block;margin-bottom:4px">Phone</label>
              <input name="phone" value="${esc(r.phone||'')}" style="width:100%;padding:8px 10px;border:1px solid var(--line);border-radius:var(--r);font-size:13px;font-family:inherit"></div>
            <div><label style="font-size:13px;font-weight:600;display:block;margin-bottom:4px">Email</label>
              <input name="email" value="${esc(r.email||'')}" style="width:100%;padding:8px 10px;border:1px solid var(--line);border-radius:var(--r);font-size:13px;font-family:inherit"></div>
          </div>
          <div><label style="font-size:13px;font-weight:600;display:block;margin-bottom:4px">Website</label>
            <input name="website" value="${esc(r.website||'')}" style="width:100%;padding:8px 10px;border:1px solid var(--line);border-radius:var(--r);font-size:13px;font-family:inherit"></div>
          <div style="display:flex;align-items:center;gap:10px">
            <label class="toggle"><input type="checkbox" name="approved" ${r.approved?'checked':''}><span class="toggle-slider"></span></label>
            <span style="font-size:13px;font-weight:600">Published</span>
          </div>
          <div id="dir-edit-error" style="display:none;color:#c00;font-size:13px"></div>
          <div style="display:flex;gap:12px;margin-top:4px">
            <button type="submit" class="btn" style="font-size:13px">Save Changes</button>
            <button type="button" id="dir-modal-cancel" style="background:none;border:none;cursor:pointer;font-size:13px;color:var(--text-soft);font-family:inherit">Cancel</button>
          </div>
        </form>
      </div>
    </div>`;
  }

  el.innerHTML = `
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
      <h1>Business Directory</h1>
      <a href="/directory" target="_blank" rel="noopener" style="color:var(--red);font-size:13px;font-weight:600">View public directory →</a>
    </div>
    <p style="margin-bottom:20px;font-size:14px;color:var(--text-soft)">Manage all business listings. Toggle the switch to publish or unpublish a listing.</p>
    <div id="dir-table">${tableHTML(allRows)}</div>`;

  // Toggle published/unpublished
  el.addEventListener('change', async (e) => {
    const cb = (e.target as HTMLElement);
    if (!cb.classList.contains('dir-toggle')) return;
    const id = Number((cb as HTMLInputElement).dataset.id);
    const approved = (cb as HTMLInputElement).checked ? 1 : 0;
    const row = allRows.find(r => r.id === id);
    if (!row) return;
    row.approved = approved;
    // Re-render just the status cell
    const td = cb.closest('td') as HTMLElement;
    const labelSpan = td.querySelector('label span:last-child') as HTMLElement;
    if (labelSpan) { labelSpan.textContent = approved ? 'Published' : 'Unpublished'; labelSpan.style.color = approved ? 'var(--ok,#16a34a)' : 'var(--text-soft)'; }
    const hintDiv = td.querySelector('div:last-child') as HTMLElement;
    if (hintDiv) hintDiv.textContent = `Tap to ${approved ? 'unpublish' : 'publish'}`;
    const badge = td.querySelector('span[style*="fef3c7"]') as HTMLElement;
    if (badge && approved) badge.remove();
    await api('/admin/api/directory/listings', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ...row, approved }),
    });
  });

  // Edit / Delete
  el.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('button') as HTMLButtonElement | null;
    if (!btn) return;
    const id = Number(btn.dataset.id);

    if (btn.classList.contains('dir-delete')) {
      if (!confirm('Delete this listing permanently?')) return;
      allRows = allRows.filter(r => r.id !== id);
      btn.closest('tr')?.remove();
      await api('/admin/api/directory/listings', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id }),
      });
      return;
    }

    if (btn.classList.contains('dir-edit')) {
      const row = allRows.find(r => r.id === id);
      if (!row) return;
      document.body.insertAdjacentHTML('beforeend', editModalHTML(row));
      const overlay = document.getElementById('dir-modal-overlay')!;
      const closeModal = () => overlay.remove();
      document.getElementById('dir-modal-close')!.addEventListener('click', closeModal);
      document.getElementById('dir-modal-cancel')!.addEventListener('click', closeModal);
      overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(); });

      document.getElementById('dir-edit-form')!.addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target as HTMLFormElement;
        const errEl = document.getElementById('dir-edit-error')!;
        const data = Object.fromEntries(new FormData(form));
        const updated = { ...row, ...data, id, approved: (form.querySelector('[name=approved]') as HTMLInputElement).checked ? 1 : 0 };
        const res = await api('/admin/api/directory/listings', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(updated),
        });
        if (res?.error) { errEl.textContent = res.error; errEl.style.display = 'block'; return; }
        // Update local data and re-render table
        const idx = allRows.findIndex(r => r.id === id);
        if (idx >= 0) allRows[idx] = updated;
        document.getElementById('dir-table')!.innerHTML = tableHTML(allRows);
        closeModal();
      });
    }
  });
}

async function renderSettings(el: HTMLElement) {
  const s = await api('/admin/api/settings');
  el.innerHTML = `
    <h1>Site Settings</h1>
    <div style="background:#fff;border:1px solid var(--line);border-radius:var(--r-lg);padding:28px;max-width:540px">
      <div class="toggle-row">
        <label class="toggle">
          <input type="checkbox" id="backorders-toggle" ${s.allow_backorders ? 'checked' : ''}>
          <span class="toggle-slider"></span>
        </label>
        <div>
          <strong>Accept out-of-stock orders (backorders)</strong>
          <p style="font-size:13px;color:var(--text-soft)">When ON: sold-out stocked items remain purchasable and enter the queue. When OFF: show "Out of stock" and block add-to-cart.</p>
        </div>
      </div>
      <div class="toggle-row" style="margin-top:20px">
        <label class="toggle">
          <input type="checkbox" id="announce-toggle" ${s.announcement_on ? 'checked' : ''}>
          <span class="toggle-slider"></span>
        </label>
        <strong>Show announcement bar</strong>
      </div>
      <div style="margin-top:12px">
        <label style="font-size:13px;font-weight:600;display:block;margin-bottom:6px">Announcement text (HTML allowed)</label>
        <textarea id="announce-text" rows="3" style="width:100%;border:1px solid var(--line);border-radius:var(--r);padding:10px;font-size:14px;font-family:var(--font-body)">${esc(s.announcement_text||'')}</textarea>
      </div>
      <button class="btn" style="margin-top:16px" id="save-settings">Save Settings</button>
      <span id="save-msg" style="margin-left:12px;font-size:13px;color:var(--ok)"></span>
    </div>`;

  document.getElementById('save-settings')?.addEventListener('click', async () => {
    const msg = document.getElementById('save-msg')!;
    await api('/admin/api/settings', {
      method: 'PUT', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({
        allow_backorders: (document.getElementById('backorders-toggle') as HTMLInputElement).checked ? 1 : 0,
        announcement_on: (document.getElementById('announce-toggle') as HTMLInputElement).checked ? 1 : 0,
        announcement_text: (document.getElementById('announce-text') as HTMLTextAreaElement).value,
      }),
    });
    msg.textContent = 'Saved!';
    setTimeout(() => { msg.textContent = ''; }, 2000);
  });
}

// Initial load
loadPanel('inventory');
</script>
)}

