  background: #fff; border-radius: var(--r-lg); padding: 36px 32px; width: 100%; max-width: 360px;
  box-shadow: 0 8px 40px rgba(0,0,0,.3);
}
.login-logo { text-align: center; margin-bottom: 28px; }
