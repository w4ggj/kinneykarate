.login-logo h1 { font-family: var(--font-condensed); text-transform: uppercase; font-size: 22px; font-weight: 700; margin-bottom: 2px; }
.login-logo p { font-size: 13px; color: var(--text-soft); }
.login-field { display: flex; flex-direction: column; gap: 5px; margin-bottom: 14px; }
