---
const nav = [
  { label: 'Programs',   href: '/programs' },
  { label: 'Locations',  href: '/locations' },
  { label: 'Events',     href: '/events' },
  { label: 'Students',   href: '/students' },
  { label: 'Directory',  href: '/directory' },
];
const aboutLinks = [
  { label: 'Our Instructors', href: '/instructors' },
  { label: 'Memorial Fund',   href: '/memorial' },
  { label: 'Our Story',       href: '/our-story' },
  { label: 'Contact Us',      href: '/contact' },
];
const { pathname } = Astro.url;
const aboutActive = ['/instructors', '/contact', '/memorial', '/our-story', '/about'].some(p => pathname.startsWith(p));
---
<header class="sitehdr">
  <div class="container sitehdr-inner">
    <a href="/" class="logo">
      <img src="/kklogo.png" alt="Kinney Karate" class="logo-img" width="40" height="40" />
      <b>Kinney Karate</b>
    </a>
    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="sitenav">
      <span></span><span></span><span></span>
    </button>
    <nav id="sitenav" class="sitenav">
      {nav.map(n => (
        <a href={n.href} class:list={[{ on: pathname.startsWith(n.href) }]}>{n.label}</a>
      ))}
      <div class:list={['nav-dropdown', { on: aboutActive }]}>
        <button class="dropdown-btn" aria-expanded="false">About Us <span class="chevron">▾</span></button>
        <div class="dropdown-menu">
          {aboutLinks.map(l => (
            <a href={l.href} class:list={[{ on: pathname.startsWith(l.href) }]}>{l.label}</a>
          ))}
        </div>
      </div>
      <a href="/store" class="btn">Shop Now</a>
      <a href="/store/checkout" id="nav-cart" class="nav-cart" aria-label="Cart">
        🛒 <span id="nav-cart-count" class="cart-badge">0</span>
      </a>
    </nav>
  </div>
</header>

<style>
.sitehdr {
  background: var(--ink);
  color: var(--text-invert);
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1px solid var(--line-ink);
}
.sitehdr-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 14px;
  padding-bottom: 14px;
}
.logo {
  display: flex;
  align-items: center;
  gap: 11px;
  flex-shrink: 0;
}
.logo-img {
  width: 40px; height: 40px;
  object-fit: contain;
  flex-shrink: 0;
}
.logo b {
  font-family: var(--font-condensed);
  text-transform: uppercase;
  letter-spacing: .05em;
  font-weight: 700;
  font-size: 19px;
}
.sitenav {
  display: flex;
  align-items: center;
  gap: 18px;
  font-size: 13px;
  color: var(--text-invert-soft);
  font-weight: 500;
}
.sitenav a { transition: color .12s; }
.sitenav a:hover, .sitenav a.on { color: #fff; }

.nav-dropdown {
  position: relative;
}
.dropdown-btn {
  background: none; border: none; cursor: pointer;
  font-size: 13px; font-weight: 500; color: var(--text-invert-soft);
  display: flex; align-items: center; gap: 4px;
  padding: 0; transition: color .12s;
  font-family: inherit;
}
.dropdown-btn:hover, .nav-dropdown.on .dropdown-btn { color: #fff; }
.chevron { font-size: 10px; transition: transform .15s; }
.nav-dropdown.open .chevron { transform: rotate(180deg); }
.dropdown-menu {
  display: none;
  position: absolute;
  top: calc(100% + 10px);
  right: 0;
  background: var(--ink-2, #1a1a2e);
  border: 1px solid var(--line-ink);
  border-radius: var(--r);
  min-width: 180px;
  padding: 6px 0;
  z-index: 200;
  box-shadow: 0 8px 24px rgba(0,0,0,.3);
}
.nav-dropdown.open .dropdown-menu { display: block; }
.dropdown-menu a {
  display: block;
  padding: 10px 18px;
  font-size: 13px;
  color: var(--text-invert-soft);
  border-bottom: none !important;
  white-space: nowrap;
}
.dropdown-menu a:hover, .dropdown-menu a.on { color: #fff; background: rgba(255,255,255,.05); }

@media (max-width: 820px) {
  .nav-dropdown { width: 100%; }
  .dropdown-btn {
    width: 100%; padding: 10px 0;
    border-bottom: 1px solid var(--line-ink);
    font-size: 14px;
  }
  .dropdown-menu {
    position: static;
    box-shadow: none;
    border: none;
    background: transparent;
    padding: 0 0 0 12px;
  }
  .nav-dropdown.open .dropdown-menu { display: block; }
  .dropdown-menu a { padding: 8px 0; font-size: 13px; border-bottom: 1px solid var(--line-ink) !important; }
}

.nav-cart {
  display: flex; align-items: center; gap: 6px;
  font-size: 15px; font-weight: 600; color: var(--text-invert-soft);
  padding: 5px 10px; border-radius: 999px;
  border: 1px solid var(--line-ink);
  transition: background .12s, color .12s;
}
.nav-cart:hover { background: rgba(255,255,255,.1); color: #fff; }
.cart-badge {
  background: var(--red); color: #fff;
  font-size: 11px; font-weight: 700;
  border-radius: 999px; padding: 1px 6px;
  min-width: 18px; text-align: center;
}

.nav-toggle { display: none; }

@media (max-width: 820px) {
  .nav-toggle {
    display: flex; flex-direction: column; gap: 4px;
    background: none; border: none; cursor: pointer; padding: 6px;
  }
  .nav-toggle span { display: block; width: 22px; height: 2px; background: var(--text-invert); border-radius: 2px; }

  .sitenav {
    display: none;
    position: absolute;
    top: 100%; left: 0; right: 0;
    flex-direction: column;
    align-items: stretch;
    background: var(--ink-2);
    padding: 16px 20px 20px;
    gap: 4px;
    border-bottom: 1px solid var(--line-ink);
  }
  .sitenav.open { display: flex; }
  .sitenav a { padding: 10px 0; border-bottom: 1px solid var(--line-ink); }
  .sitenav a:last-child { border-bottom: none; margin-top: 8px; }
  .sitehdr { position: relative; }
}
</style>

<script>
// Dropdown
const dropdown = document.querySelector('.nav-dropdown');
const dropBtn = dropdown?.querySelector('.dropdown-btn');
dropBtn?.addEventListener('click', (e) => {
  e.stopPropagation();
  const open = dropdown.classList.toggle('open');
  dropBtn.setAttribute('aria-expanded', String(open));
});
document.addEventListener('click', () => dropdown?.classList.remove('open'));

const btn = document.querySelector('.nav-toggle');
const nav = document.getElementById('sitenav');
btn?.addEventListener('click', () => {
  const open = nav.classList.toggle('open');
  btn.setAttribute('aria-expanded', String(open));
});

// Keep cart badge in sync
function syncCartBadge() {
  try {
    const cart = JSON.parse(sessionStorage.getItem('kk_cart') || '[]');
    const n = cart.reduce((s: number, i: any) => s + i.qty, 0);
    const badge = document.getElementById('nav-cart-count');
    if (badge) badge.textContent = String(n);
  } catch {}
}
syncCartBadge();
// Re-sync when cart is updated on this page (product pages dispatch storage event)
window.addEventListener('kk-cart-updated', syncCartBadge);
</script>
