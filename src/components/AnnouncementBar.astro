---
// Announcement bar — loads client-side so it works on prerendered pages too.
---
<div id="annobar" class="annobar" role="banner" style="display:none"></div>

<style>
.annobar {
  background: var(--red);
  color: #fff;
  text-align: center;
  padding: 8px 20px;
  font-size: 13.5px;
  font-weight: 500;
  line-height: 1.4;
}
.annobar a { text-decoration: underline; }
</style>

<script>
fetch('/api/announcement')
  .then(r => r.json())
  .then(d => {
    if (d.on && d.text) {
      const bar = document.getElementById('annobar');
      if (bar) { bar.innerHTML = d.text; bar.style.display = ''; }
    }
  })
  .catch(() => {});
</script>
